---
import { SOCIAL_LINKS, NAV_LINKS, SITE } from '@/consts'
import SocialIcons from './SocialIcons.astro'
import Link from '@/components/Link.astro'
---

<footer class="bg-background/80 border-t border-border/50 backdrop-blur-md">
  <div class="w-full px-4 py-8 sm:py-10">
    <div class="flex flex-col gap-8 max-w-3xl mx-auto">
      <!-- Main Footer Content -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 lg:gap-8">
        <!-- Navigation -->
        <div>
          <h4 class="text-sm font-semibold mb-3 text-foreground">Navigation</h4>
          <nav class="flex flex-col gap-2">
            {NAV_LINKS.map((item) => {
              const isExternal = item.href.startsWith('http')
              return (
                <Link
                  href={item.href}
                  class="text-sm text-muted-foreground hover:text-primary capitalize transition-colors flex items-center gap-1.5 group"
                >
                  <span>{item.label}</span>
                </Link>
              )
            })}
          </nav>
        </div>

        <!-- Connect -->
        <div>
          <h4 class="text-sm font-semibold mb-3 text-foreground">Connect</h4>
          <SocialIcons links={SOCIAL_LINKS} />
        </div>
      </div>

      <!-- Separator -->
      <div class="h-px bg-border/60" aria-hidden="true"></div>

      <!-- Bottom Section -->
      <div class="flex flex-col items-center gap-2 sm:flex-row sm:justify-between text-sm text-muted-foreground">
        <div class="text-center sm:text-left">
          &copy; {new Date().getFullYear()} {SITE.title}. All rights reserved.
        </div>
        <div class="text-xs text-muted-foreground/80">
          <span>
            Theme: <a href="https://github.com/meroxdotdev/merox-erudite" target="_blank" rel="noopener noreferrer" class="underline hover:text-foreground transition-colors">merox-erudite</a>
          </span>
        </div>
      </div>
    </div>
  </div>
</footer>
